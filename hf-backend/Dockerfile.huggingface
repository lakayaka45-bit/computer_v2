FROM node:20-alpine

RUN addgroup -S appgroup && adduser -S appuser -G appgroup

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install --production

# Copy source code
COPY . .

# Generate Prisma client from the backend schema
RUN npx prisma generate --schema=./prisma/schema.prisma

EXPOSE 7860

USER appuser

CMD ["npm", "start"]
